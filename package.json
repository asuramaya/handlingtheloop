{
  "name": "htl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, serverless DJ software that mixes public YouTube playlists, rekordbox-style.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.node.json",
    "worker": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "deploy:admin": "wrangler deploy -c wrangler.admin.jsonc"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wrangler": "^4.98.0",
    "youtubei.js": "^17.0.1"
  }
}
