{
  // Typechecks the non-bundled code (Cloudflare Worker + shared server modules +
  // build config) that tsconfig.json's `include: ["src"]` leaves out. Run via
  // `pnpm typecheck` alongside the src build so backend type errors surface.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["server", "worker", "vite.config.ts"]
}
